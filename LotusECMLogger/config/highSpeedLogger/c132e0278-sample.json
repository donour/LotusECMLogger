{
  // Sample preset for the C132E0278 (GT430) ECU. Scalar channels reference symbols by name; the app
  // resolves each one's address, size, scale, offset and unit from
  // config/highSpeedLogger/database/C132E0278.csv (parsed from the Ghidra "Data Type"). Per-cylinder
  // values live in [6] arrays the catalog hides, so they are listed as explicit address channels
  // (base + element offset, with defaultSelected so they start checked). Use "Add Channels…" in the
  // High-Speed Log tab to browse the full catalog.
  "name": "GT430 Sample (C132E0278)",
  "description": "TPS, pedal, per-cylinder ignition advance & knock retard, AFR, MAF, load, IAT.",
  "ecuVersion": "C132E0278",
  "channels": [
    { "symbol": "tps_8bit",              "rate": 100 },
    { "symbol": "accel_pedal_pos_16bit", "rate": 100 },

    // Ignition advance per cylinder — obd_ii_ign_adv_per_cylinder, i16_angle_1/4deg[6] @ 0x40001924
    { "name": "Ign Advance Cyl 1", "address": "0x40001924", "size": 2, "signed": true, "scale": 0.25, "unit": "deg", "defaultSelected": true, "rate": 100 },
    { "name": "Ign Advance Cyl 2", "address": "0x40001926", "size": 2, "signed": true, "scale": 0.25, "unit": "deg", "defaultSelected": true, "rate": 100 },
    { "name": "Ign Advance Cyl 3", "address": "0x40001928", "size": 2, "signed": true, "scale": 0.25, "unit": "deg", "defaultSelected": true, "rate": 100 },
    { "name": "Ign Advance Cyl 4", "address": "0x4000192a", "size": 2, "signed": true, "scale": 0.25, "unit": "deg", "defaultSelected": true, "rate": 100 },
    { "name": "Ign Advance Cyl 5", "address": "0x4000192c", "size": 2, "signed": true, "scale": 0.25, "unit": "deg", "defaultSelected": true, "rate": 100 },
    { "name": "Ign Advance Cyl 6", "address": "0x4000192e", "size": 2, "signed": true, "scale": 0.25, "unit": "deg", "defaultSelected": true, "rate": 100 },

    // Knock retard per cylinder — ign_retard_knock, u8_angle_1/4deg[6] @ 0x40001e38
    { "name": "Knock Retard Cyl 1", "address": "0x40001e38", "size": 1, "scale": 0.25, "unit": "deg", "defaultSelected": true, "rate": 100 },
    { "name": "Knock Retard Cyl 2", "address": "0x40001e39", "size": 1, "scale": 0.25, "unit": "deg", "defaultSelected": true, "rate": 100 },
    { "name": "Knock Retard Cyl 3", "address": "0x40001e3a", "size": 1, "scale": 0.25, "unit": "deg", "defaultSelected": true, "rate": 100 },
    { "name": "Knock Retard Cyl 4", "address": "0x40001e3b", "size": 1, "scale": 0.25, "unit": "deg", "defaultSelected": true, "rate": 100 },
    { "name": "Knock Retard Cyl 5", "address": "0x40001e3c", "size": 1, "scale": 0.25, "unit": "deg", "defaultSelected": true, "rate": 100 },
    { "name": "Knock Retard Cyl 6", "address": "0x40001e3d", "size": 1, "scale": 0.25, "unit": "deg", "defaultSelected": true, "rate": 100 },

    { "symbol": "afr_commanded",         "rate": 50 },
    { "symbol": "map",                   "rate": 50 },
    { "symbol": "maf_flow",              "rate": 50 },
    { "symbol": "load_mass_per_stroke",  "rate": 50 },
    { "symbol": "torque_limit",                 "rate": 50 },
    { "symbol": "torque_net_engine_combustion", "rate": 50 },
    { "symbol": "iat",                   "rate": 5  }
  ]
}
